{
  "manifest_version": 3,
  "name": "Bolt Download Manager",
  "description": "Intercept browser downloads and send them to Bolt download manager",
  "version": "0.1.0",
  "permissions": [
    "downloads",
    "cookies",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "offline_enabled": true,
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bolt Download Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
