{
  "manifest_version": 3,
  "name": "Bolt Download Manager",
  "description": "Intercept browser downloads and send them to Bolt download manager",
  "version": "0.3.2",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "webRequest"
  ],
  "optional_permissions": [
    "cookies"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bolt@boltdm.site",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "offline_enabled": true,
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bolt Download Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
